# ── Raqib gateway configuration ──────────────────────────────────────────────
# Copy to .env and edit. NEVER commit .env (see ../.gitignore).

# Model backend: "mock" (deterministic vulnerable demo model, no deps) or "ollama"
LLM_BACKEND=mock
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# LLM-as-judge detection layer:
#   off        = signatures + output inspection only (fastest)
#   suspicious = run the judge only when signatures already flagged something (default)
#   always     = run the judge on every prompt (highest recall, highest latency)
LLM_JUDGE_MODE=suspicious
JUDGE_MODEL=llama3

# Event store
DB_PATH=raqib_events.db

# SOAR policy
#   Comma-separated severities that cause an inbound prompt to be BLOCKED.
BLOCK_SEVERITIES=high,critical
#   Number of high/critical offenses in a session before the session is quarantined.
QUARANTINE_THRESHOLD=5
RATE_LIMIT_PER_MIN=60

# Wazuh SIEM forwarding (Phase 6). Leave disabled until Wazuh is running.
WAZUH_ENABLED=false
WAZUH_HOST=127.0.0.1
WAZUH_PORT=514
