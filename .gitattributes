# Normalise line endings so the repo is consistent across Windows/Linux/Docker.
* text=auto eol=lf

# Windows-native scripts keep CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat these as binary (never diff/merge as text)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
